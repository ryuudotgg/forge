{
	"name": "@ryuujs/forge",
	"version": "0.1.0",
	"description": "An all-in-one starter for your next big thing.",
	"keywords": [
		"forge"
	],
	"homepage": "https://forge.ryuu.gg",
	"bugs": {
		"url": "https://github.com/ryuudotgg/forge/issues",
		"email": "contact@ryuu.gg"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ryuudotgg/forge.git",
		"directory": "packages/cli"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/ryuudotgg"
	},
	"license": "MIT",
	"author": {
		"name": "Ryuu",
		"email": "me@ryuu.gg",
		"url": "https://ryuu.gg"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"bin": "./dist/index.mjs",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"check": "biome check",
		"clean": "git clean -xdf .turbo .cache dist node_modules",
		"dev": "tsdown --watch",
		"prepare": "effect-language-service patch --dir ../../node_modules/typescript",
		"start": "node ./dist/index.mjs",
		"test": "vitest run test",
		"typecheck": "tsc"
	},
	"dependencies": {
		"@clack/core": "catalog:node",
		"@clack/prompts": "catalog:node",
		"@effect/platform": "catalog:effect",
		"@effect/platform-node": "catalog:effect",
		"@ryuujs/core": "workspace:*",
		"@ryuujs/generators": "workspace:*",
		"effect": "catalog:effect",
		"picocolors": "catalog:node"
	},
	"devDependencies": {
		"@effect/language-service": "^0.85.1",
		"@ryuujs/tsconfig": "workspace:*",
		"@types/node": "catalog:dev",
		"tsdown": "catalog:build",
		"typescript": "catalog:dev"
	}
}
