generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "__DATASOURCE_PROVIDER__"__RELATION_MODE__
}

model User {
  id            String   @id

  name          String__TEXT__
  image         String?__TEXT__

  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")

  createdAt     DateTime @default(now()) @map("created_at")__TIMESTAMPTZ__
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")__TIMESTAMPTZ__

  sessions Session[]
  accounts Account[]

  @@map("users")
}

model Session {
  id        String   @id
  userId    String   @map("user_id")

  token     String   @unique
  expiresAt DateTime @map("expires_at")__TIMESTAMPTZ__

  ipAddress String?  @map("ip_address")__TEXT__
  userAgent String?  @map("user_agent")__TEXT__

  createdAt DateTime @default(now()) @map("created_at")__TIMESTAMPTZ__
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")__TIMESTAMPTZ__

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])

  @@map("sessions")
}

model Account {
  id                    String    @id
  userId                String    @map("user_id")

  accountId             String    @map("account_id")__TEXT__
  providerId            String    @map("provider_id")__TEXT__

  accessToken           String?   @map("access_token")__TEXT__
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")__TIMESTAMPTZ__

  refreshToken          String?   @map("refresh_token")__TEXT__
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")__TIMESTAMPTZ__

  scope                 String?__TEXT__

  createdAt             DateTime  @default(now()) @map("created_at")__TIMESTAMPTZ__
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")__TIMESTAMPTZ__

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])

  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String__TEXT__

  value      String__TEXT__
  expiresAt  DateTime @map("expires_at")__TIMESTAMPTZ__

  createdAt  DateTime @default(now()) @map("created_at")__TIMESTAMPTZ__
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")__TIMESTAMPTZ__

  @@map("verifications")
}
