generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "__DATASOURCE_PROVIDER__"__RELATION_MODE__
}

model User {
  id            String   @id

  name          String__TEXT__
  image         String?__TEXT__

  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")

  createdAt     DateTime @default(now()) @map("created_at")__TIMESTAMPTZ__
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")__TIMESTAMPTZ__

  @@map("users")
}
