{
	"name": "@ryuujs/generators",
	"version": "0.1.0",
	"description": "Built-in generators for Forge.",
	"keywords": [
		"forge"
	],
	"homepage": "https://forge.ryuu.gg",
	"bugs": {
		"url": "https://github.com/ryuudotgg/forge/issues",
		"email": "contact@ryuu.gg"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ryuudotgg/forge.git",
		"directory": "packages/generators"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/ryuudotgg"
	},
	"license": "MIT",
	"author": {
		"name": "Ryuu",
		"email": "me@ryuu.gg",
		"url": "https://ryuu.gg"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"check": "biome check",
		"clean": "git clean -xdf .turbo .cache dist node_modules",
		"dev": "tsdown --watch",
		"typecheck": "tsc"
	},
	"dependencies": {
		"@ryuujs/core": "workspace:*",
		"effect": "catalog:effect"
	},
	"devDependencies": {
		"@ryuujs/tsconfig": "workspace:*",
		"@types/node": "catalog:dev",
		"tsdown": "catalog:build",
		"typescript": "catalog:dev"
	}
}
